<% layout('/layouts/boilerplate.ejs') %>

<style>
  body{
    background: #f8f9fa;
  }

  .orders-header{
    font-weight: 700;
    font-size: 2rem;
    color: #222;
  }

  .orders-subtitle{
    color: #6c757d;
    font-size: 0.95rem;
  }

  .order-card{
    border: none;
    border-radius: 18px;
    overflow: hidden;
    transition: 0.3s ease;
    background: #fff;
  }

  .order-card:hover{
    transform: translateY(-6px);
    box-shadow: 0 14px 30px rgba(0,0,0,0.08);
  }

  .top-strip{
    height: 6px;
    background: linear-gradient(90deg,#0d6efd,#6610f2,#20c997);
  }

  .listing-title{
    font-weight: 700;
    font-size: 1.2rem;
    color: #222;
  }

  .detail-label{
    font-weight: 600;
    color: #555;
  }

  .info-box{
    background: #f8f9fa;
    border-radius: 12px;
    padding: 10px 14px;
    margin-bottom: 10px;
  }

  .empty-box{
    background: white;
    padding: 50px;
    border-radius: 20px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
  }

  .status-badge{
    font-size: 0.8rem;
    padding: 8px 14px;
    border-radius: 20px;
  }

  .date-box{
    background: #eef4ff;
    border-radius: 12px;
    padding: 10px;
  }

  .price{
    font-size: 1.25rem;
    font-weight: 700;
    color: #198754;
  }
</style>

<div class="container py-5">

  <div class="text-center mb-5">
    <h2 class="orders-header">My Bookings</h2>
    <p class="orders-subtitle">Track all your stays and reservation history</p>
  </div>

  <% if (orders.length === 0) { %>

    <div class="row justify-content-center">
      <div class="col-md-7">
        <div class="empty-box text-center">
          <h4>No bookings yet 🏡</h4>
          <p class="text-muted mt-2">Start exploring amazing stays and make your first reservation.</p>

          <a href="/listings" class="btn btn-dark mt-3 px-4 rounded-pill">
            Explore Stays
          </a>
        </div>
      </div>
    </div>

  <% } %>

  <div class="row g-4">

    <% orders.forEach(order => { %>

      <div class="col-lg-6">
        <div class="card order-card shadow-sm h-100">

          <div class="top-strip"></div>

          <div class="card-body p-4">

            <div class="d-flex justify-content-between align-items-start mb-3">
              <h5 class="listing-title mb-0">
                <%= order.listing.title %>
              </h5>

              <span class="badge bg-success status-badge text-capitalize">
                <%= order.status %>
              </span>
            </div>

            <div class="info-box">
              <span class="detail-label">Location:</span>
              <%= order.listing.location %>, <%= order.listing.country %>
            </div>

            <div class="row">
              <div class="col-md-6">
                <div class="date-box mb-3">
                  <small class="text-muted d-block">Check-In</small>
                  <b><%= order.checkIn %></b>
                </div>
              </div>

              <div class="col-md-6">
                <div class="date-box mb-3">
                  <small class="text-muted d-block">Check-Out</small>
                  <b><%= order.checkOut %></b>
                </div>
              </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-3">

              <div>
                <small class="text-muted d-block">Payment</small>
                <b><%= order.paymentType %></b>
              </div>

              <div class="text-end">
                <small class="text-muted d-block">Total</small>
                <div class="price">₹<%= order.amount %></div>
              </div>

            </div>

          </div>
        </div>
      </div>

    <% }) %>

  </div>

</div>