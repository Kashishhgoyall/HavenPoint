<% layout('/layouts/boilerplate.ejs') %>

<% block('style').append('index') %>

<div class="filter">
    <!-- ALL BUTTON -->
    <a href="/listings" class="text-decoration-none text-dark">
        <div class="filters <%= !selectedCategory ? 'active-filter' : '' %>">
            <p>All</p>
        </div>
    </a>

    <% for(let category in listingCategories) { %>

        <a href="/listings?category=<%= category %>" class="text-decoration-none text-dark">
            <div class="filters <%= category === selectedCategory ? 'active-filter' : '' %>">
                <i class="<%= listingCategories[category] %>"></i>
                <p><%= category %></p>
            </div>
        </a>

    <% } %>

    <div class="tax-toggle">
        <div class="form-check-reverse form-switch">
            <input class="form-check-input" type="checkbox" id="switchCheckDefault">
            <label class="form-check-label">Display total after Taxes</label>
        </div>
    </div>
</div>

<p class="ms-3 mb-0 fw-bold">
    Find your next adventure <i class="fa-solid fa-arrow-right"></i>
</p>

<!-- ================= LISTINGS ================= -->

<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mb-4">

    <% if(allListings.length > 0) { %>

        <% for(let listings of allListings) { %>

            <a href="/listings/<%= listings._id %>" class="listing-link">
                <div class="card listing-card m-3">

                    <img
                        src="<%= listings.image.url %>"
                        class="card-img-top"
                        alt="listing-img"
                    />

                    <div class="card-img-overlay">
                        <b><%= listings.title.split(' ')[0] %></b>
                    </div>

                    <div class="card-body">
                        <p class="card-text">
                            <b><%= listings.title %></b> <br>
                            &#x20B9; <%= listings.price.toLocaleString('en-IN') %> / night
                            &nbsp; <i class="gst">+18% gst</i>
                        </p>
                    </div>

                </div>
            </a>

        <% } %>

    <% } else { %>

        <p class="ms-3 text-muted">No listings found for this category</p>

    <% } %>

</div>

<script src="/js/index.js"></script>