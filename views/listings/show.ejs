<% layout('/layouts/boilerplate.ejs') %>

<% block('style').append('show') %>
<%- include('../includes/checkoutScript.ejs') %>

<div class="row mt-3 mb-5">
  <div class="col-12 col-md-6 offset-md-3 text-center mb-2">
    <h2><%= listing.title %></h2>
  </div>

  <div class="col-12 col-md-6 offset-md-3">
    <div class="card shadow-sm p-4">

      <img src="<%= listing.image.url %>" class="card-img-top s-img" />

      <div class="card-body">

        <p><b>Owner:</b> <%= listing.owner.username %></p>

        <p><%= listing.description %></p>

        <p>
          <b>Price:</b> ₹<%= listing.price %> / night |
          <b>Location:</b> <%= listing.location %>, <%= listing.country %>
        </p>

        <% if (currUser && !currUser._id.equals(listing.owner._id)) { %>

        <!-- ================= BOOKING SECTION ================= -->
        <div class="card p-3 mt-3">

          <h5>Book this stay</h5>

          <!-- DATE + GUEST INPUT -->
          <div class="mb-2">
            <label>Check-in</label>
            <input type="date" id="checkIn" class="form-control" required>
          </div>

          <div class="mb-2">
            <label>Check-out</label>
            <input type="date" id="checkOut" class="form-control" required>
          </div>

          <div class="mb-2">
            <label>Guests</label>
            <input type="number" id="guests" class="form-control" value="1" min="1">
          </div>

          <!-- COD -->
          <form method="POST" action="/orders" id="codForm">
            <input type="hidden" name="listingId" value="<%= listing._id %>">
            <input type="hidden" name="amount" value="<%= listing.price %>">
            <input type="hidden" name="checkIn" id="codCheckIn">
            <input type="hidden" name="checkOut" id="codCheckOut">
            <input type="hidden" name="guests" id="codGuests">

            <button type="submit" class="btn btn-dark w-100 mt-2">
              Pay at Property (COD)
            </button>
          </form>

          <!-- RAZORPAY -->
          <button 
            class="btn btn-success w-100 mt-2 razorpay-btn"
            data-listing-id="<%= listing._id %>"
            data-price="<%= listing.price %>">
            Pay Online
          </button>

        </div>
        <!-- =================================================== -->

        <% } %>

      </div>
    </div>
  </div>
</div>

<script>
  const checkIn = document.getElementById("checkIn");
  const checkOut = document.getElementById("checkOut");
  const guests = document.getElementById("guests");

  const codCheckIn = document.getElementById("codCheckIn");
  const codCheckOut = document.getElementById("codCheckOut");
  const codGuests = document.getElementById("codGuests");

  const codForm = document.getElementById("codForm");

  function updateFields() {
    codCheckIn.value = checkIn.value;
    codCheckOut.value = checkOut.value;
    codGuests.value = guests.value;
  }

  checkIn?.addEventListener("change", updateFields);
  checkOut?.addEventListener("change", updateFields);
  guests?.addEventListener("input", updateFields);

  // 🔥 VALIDATION BEFORE COD SUBMIT
  codForm?.addEventListener("submit", function(e) {
    if (!checkIn.value || !checkOut.value) {
      e.preventDefault();
      alert("Please select check-in and check-out dates");
    } else if (new Date(checkOut.value) <= new Date(checkIn.value)) {
      e.preventDefault();
      alert("Check-out must be after check-in");
    }
  });
</script>