<% layout('/layouts/boilerplate.ejs') %>
<% block('style').append('show') %>

<div class="container mt-4 mb-5">

  <h2 class="text-center fw-bold mb-4"><%= listing.title %></h2>

  <div class="row g-4">

    <!-- LEFT -->
    <div class="col-lg-8">

      <img
        src="<%= listing.image.url %>"
        class="img-fluid w-100 listing-main-img shadow"
        style="height:500px;"
      >

      <div class="card p-4 shadow-sm mt-4">
        <h4>About this stay</h4>
        <p><%= listing.description %></p>

        <p>
          <b>Owner:</b> <%= listing.owner.username %><br>
          <b>Location:</b> <%= listing.location %>, <%= listing.country %><br>
          <b>Price:</b> ₹<%= listing.price %> / night
        </p>
      </div>

      <!-- MAP -->
      <div class="card p-4 shadow-sm mt-4">
        <h4>Where you'll be</h4>
        <div id="map"></div>
      </div>

      <!-- REVIEWS -->
      <div class="card p-4 shadow-sm mt-4">
        <h4 class="mb-3">Reviews</h4>

        <% if(listing.reviews.length === 0){ %>
          <p>No reviews yet.</p>
        <% } %>

        <% listing.reviews.forEach(review => { %>
          <div class="review-card border p-3 mb-3">

            <b><%= review.author.username %></b>

            <div class="mb-2 text-warning">
              <% for(let i=1;i<=5;i++){ %>
                <% if(i <= review.rating){ %>
                  ★
                <% } else { %>
                  ☆
                <% } %>
              <% } %>
            </div>

            <p class="review-text mb-0"><%= review.comment %></p>

          </div>
        <% }) %>

        <% if(currUser){ %>

        <hr>

        <form method="POST" action="/listings/<%= listing._id %>/reviews">

          <div class="mb-3">
            <label>Rating</label>
            <select class="form-select" name="review[rating]">
              <option value="5">5 Star</option>
              <option value="4">4 Star</option>
              <option value="3">3 Star</option>
              <option value="2">2 Star</option>
              <option value="1">1 Star</option>
            </select>
          </div>

          <div class="mb-3">
            <label>Comment</label>
            <textarea
              class="form-control"
              rows="3"
              name="review[comment]"
              required
            ></textarea>
          </div>

          <button class="btn btn-dark">
            Submit Review
          </button>

        </form>

        <% } else { %>

          <a href="/login" class="btn btn-outline-dark">
            Login to Review
          </a>

        <% } %>

      </div>

    </div>

    <!-- RIGHT -->
    <div class="col-lg-4">

      <% if (currUser && !currUser._id.equals(listing.owner._id)) { %>

      <div class="card p-4 shadow-sm sticky-top" style="top:90px;">
        <h4>Book this stay</h4>

        <input type="date" class="form-control mb-2" id="checkIn">
        <input type="date" class="form-control mb-2" id="checkOut">
        <input type="number" class="form-control mb-3" id="guests" value="1" min="1">

        <form method="POST" action="/orders">
          <input type="hidden" name="listingId" value="<%= listing._id %>">
          <input type="hidden" name="amount" value="<%= listing.price %>">

          <button class="btn btn-dark w-100 mb-2">
            Pay at Property
          </button>
        </form>

        <button
          class="btn btn-success w-100 razorpay-btn"
          data-listing-id="<%= listing._id %>"
          data-price="<%= listing.price %>">
          Pay Online
        </button>

      </div>

      <% } %>

    </div>

  </div>

</div>

<script>
const coords = <%- JSON.stringify(listing.geometry.coordinates) %>;

const map = L.map('map').setView(
  [coords[1], coords[0]], 11
);

L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png',{
  maxZoom:19
}).addTo(map);

L.marker([coords[1], coords[0]])
.addTo(map)
.bindPopup("<%= listing.title %>")
.openPopup();
</script>